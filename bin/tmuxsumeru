#!/bin/bash

TARGET_NAME="sumerus-macbook-pro"
TARGET_USER="sumeruchatterjee"
SESSION_NAME="sumerus-mac"

# Resolve IP from tailscale network
TARGET_IP=$(tailscale status --json 2>/dev/null | python3 -c "
import sys,json
data=json.load(sys.stdin)
name='$TARGET_NAME'
for node in [data['Self']] + list(data['Peer'].values()):
    if node['DNSName'].startswith(name + '.'):
        print(node['TailscaleIPs'][0])
        break
" 2>/dev/null)

if [[ -z "$TARGET_IP" ]]; then
    echo "$TARGET_NAME not found on tailnet"
    exit 1
fi

CURRENT_TS_IP=$(tailscale ip -4 2>/dev/null)

if [[ "$CURRENT_TS_IP" == "$TARGET_IP" ]]; then
    # Install tmux if missing
    if ! command -v tmux &>/dev/null; then
        echo "Installing tmux..."
        brew install tmux
    fi
    # Local — attach or create tmux session
    if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
        exec tmux attach -t "$SESSION_NAME"
    else
        exec tmux new-session -s "$SESSION_NAME"
    fi
else
    # Remote — SSH in, install tmux if needed, then attach or create session
    exec ssh -t "$TARGET_USER@$TARGET_IP" "export PATH=/usr/local/bin:/opt/homebrew/bin:\$PATH; command -v tmux &>/dev/null || brew install tmux; tmux attach -t $SESSION_NAME 2>/dev/null || tmux new-session -s $SESSION_NAME"
fi

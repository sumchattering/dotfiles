#!/bin/bash

TARGET_IP="100.87.219.84"
TARGET_USER="sumeruchatterjee"
TARGET_HOST="sumerus-macbook-pro"

# Check if we're already on the target machine
CURRENT_TS_IP=$(tailscale ip -4 2>/dev/null)
if [[ "$CURRENT_TS_IP" == "$TARGET_IP" ]]; then
    echo "You're already on $TARGET_HOST ($TARGET_IP)"
    exit 0
fi

# Check if SSH key exists, generate if not
if [[ ! -f ~/.ssh/id_ed25519 ]]; then
    echo "No SSH key found. Generating one..."
    ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -N ""
    ssh-add --apple-use-keychain ~/.ssh/id_ed25519 2>/dev/null || ssh-add ~/.ssh/id_ed25519
fi

# Check if we can connect without password
if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$TARGET_USER@$TARGET_IP" true 2>/dev/null; then
    echo "First time setup: copying SSH key to $TARGET_HOST..."
    echo "You'll be asked for your password once."
    ssh-copy-id -i ~/.ssh/id_ed25519.pub "$TARGET_USER@$TARGET_IP"
fi

ssh "$TARGET_USER@$TARGET_IP" "$@"
